# Copy to `.env` (name must match exactly — Clerk publishable key, not "LARK"):
# https://dashboard.clerk.com → API Keys → Publishable key
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Local release APK: run `npm run android:apk:release` so prebuild reads this file and embeds the key.
# EAS cloud build: add the same variable in https://expo.dev → Project → Environment variables
#   (Preview / Production as needed). `.env` is not uploaded to EAS when gitignored.

# Clerk Dashboard → Native applications → iOS/Android redirect URL:
# devault://oauth-callback
