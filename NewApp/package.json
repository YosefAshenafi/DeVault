{
  "name": "newapp",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "cd android && ./gradlew assembleDebug",
    "build:android-release": "cd android && ./gradlew assembleRelease",
    "install:android": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "install:android-release": "adb install -r android/app/build/outputs/apk/release/app-release.apk"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-navigation/bottom-tabs": "^7.15.13",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.14.14",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.22",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-share-intent": "5.1.1",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^1.14.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1"
